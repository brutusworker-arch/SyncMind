# PowerSync Cloud Project URL
# Get from https://app.powersync.com → your project → Connection details
VITE_POWERSYNC_URL=https://your-project-id.powersync.journeyapps.com

# Supabase Project URL and anon key
# Get from https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API Key
# Get from https://console.anthropic.com → API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
